# --- core ---
DATABASE_URL=postgresql+asyncpg://smartchat:smartchat@postgres:5432/smartchat
REDIS_URL=redis://redis:6379/0
SECRET_KEY=change-me-64-hex
CREDENTIALS_MASTER_KEY=change-me-32-bytes-base64
PUBLIC_BASE_URL=https://chat.chilling.com.hk
ASSETS_BASE_URL=https://chat.chilling.com.hk

# --- object storage ---
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=smartchat
MINIO_ROOT_PASSWORD=smartchat-secret
MINIO_BUCKET=smartchat
MINIO_SECURE=false

# --- LLM (sub2api relay; anthropic or openai_compat) ---
LLM_PROVIDER=anthropic
LLM_BASE_URL=https://your-sub2api-host
LLM_API_KEY=sk-...
LLM_MODEL_FAST=claude-haiku-4-5-20251001
LLM_MODEL_SMART=claude-sonnet-5
LLM_MODEL_EMBED=text-embedding-3-large

# --- channels (fill per environment) ---
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=
